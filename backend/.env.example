# Gemini API Credentials (from Google AI Studio)
GEMINI_API_KEY=GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Firebase Admin Configuration
# You can either provide the path to your Firebase Service Account JSON file:
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/serviceAccountKey.json

# OR provide credentials directly (recommended for deployment/hosting envs):
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC7...\n-----END PRIVATE KEY-----\n"

# Firebase Storage Bucket URL (without gs:// prefix)
FIREBASE_STORAGE_BUCKET=your-firebase-project.appspot.com

# API Configuration
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO
ALLOW_ORIGINS=*
